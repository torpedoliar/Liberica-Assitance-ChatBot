rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'yohanesoctav@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
      );
    }

    function isValidAdmin(data) {
      return data.keys().hasAll(['email', 'createdAt', 'addedBy'])
        && data.keys().size() == 3
        && data.email is string && data.email.size() <= 200
        && data.addedBy is string && data.addedBy.size() <= 200
        && data.createdAt == request.time;
    }

    function isValidSession(data) {
      return data.keys().hasAll(['currentMode', 'messages', 'appState', 'updatedAt', 'title', 'isPinned'])
        && data.keys().size() == 6
        && data.currentMode is string && data.currentMode.size() <= 100
        && data.messages is string && data.messages.size() <= 1048576
        && data.appState is string && data.appState.size() <= 1048576
        && data.updatedAt == request.time
        && data.title is string && data.title.size() <= 100
        && data.isPinned is bool;
    }

    function isSaveSession() {
      return incoming().diff(existing()).affectedKeys().hasOnly(['currentMode', 'messages', 'appState', 'updatedAt']);
    }
    
    function isPinSession() {
      return incoming().diff(existing()).affectedKeys().hasOnly(['isPinned', 'updatedAt']);
    }

    function isRenameSession() {
      return incoming().diff(existing()).affectedKeys().hasOnly(['title', 'updatedAt']);
    }

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow list: if isAdmin();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /{path=**}/sessions/{sessionId} {
      allow list, get: if isAdmin();
    }

    match /users/{userId}/sessions/{sessionId} {
      allow get: if isSignedIn() && request.auth.uid == userId
                 && isValidId(userId) && isValidId(sessionId);
      
      allow list: if isSignedIn() && request.auth.uid == userId
                  && isValidId(userId);

      allow create: if isSignedIn() && request.auth.uid == userId
                    && isValidId(userId) && isValidId(sessionId)
                    && isValidSession(incoming());

      allow update: if isSignedIn() && request.auth.uid == userId
                    && isValidId(userId) && isValidId(sessionId)
                    && isValidSession(incoming())
                    && (isSaveSession() || isPinSession() || isRenameSession());

      allow delete: if isSignedIn() && request.auth.uid == userId
                    && isValidId(userId) && isValidId(sessionId);
    }

    match /admins/{adminEmail} {
      allow get, list: if isAdmin();
      allow create: if isAdmin() && isValidAdmin(incoming()) && incoming().email == adminEmail;
      allow update: if false;
      allow delete: if isAdmin() && adminEmail != 'yohanesoctav@gmail.com';
    }
  }
}
