{
  "entities": {
    "AdminUser": {
      "title": "AdminUser",
      "description": "Represents an administrator with special dashboard access.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "The admin's email address."
        },
        "addedBy": {
          "type": "string",
          "description": "Email of the admin who added this user."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["email", "addedBy", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "A user profile record.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "User's email"
        },
        "lastLogin": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["email", "lastLogin"]
    },
    "Session": {
      "title": "Session",
      "description": "A chat session representing conversation state.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "Auto-generated session title."
        },
        "currentMode": {
          "type": "string"
        },
        "mode": {
          "type": "string",
          "description": "Legacy/Apparent mistyped mode param occasionally queried."
        },
        "messages": {
          "type": "string",
          "description": "Stringified JSON of messages."
        },
        "appState": {
          "type": "string",
          "description": "Stringified JSON of app state."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "isPinned": {
          "type": "boolean"
        }
      },
      "required": ["currentMode", "messages", "appState", "updatedAt"]
    },
    "TestConnection": {
      "title": "TestConnection",
      "description": "A test connection document to verify Firestore readiness.",
      "type": "object",
      "properties": {}
    }
  },
  "firestore": {
    "admins/{emailId}": {
      "schema": { "$ref": "AdminUser" },
      "description": "Administrators collection."
    },
    "users/{userId}": {
      "schema": { "$ref": "User" },
      "description": "User profiles."
    },
    "users/{userId}/sessions/{sessionId}": {
      "schema": { "$ref": "Session" },
      "description": "User chat sessions."
    },
    "test/connection": {
      "schema": { "$ref": "TestConnection" },
      "description": "Firestore connection check document"
    }
  }
}