{
  "entities": {
    "Session": {
      "title": "Session",
      "description": "User session containing chat history and app state",
      "type": "object",
      "properties": {
        "currentMode": {
          "type": "string",
          "description": "The current mode of the app"
        },
        "messages": {
          "type": "string",
          "description": "JSON stringified messages"
        },
        "appState": {
          "type": "string",
          "description": "JSON stringified app state"
        },
        "updatedAt": {
          "type": "number",
          "description": "Timestamp of last update"
        },
        "title": {
          "type": "string",
          "description": "The title of the session"
        },
        "isPinned": {
          "type": "boolean",
          "description": "Whether the session is pinned"
        }
      },
      "required": ["currentMode", "messages", "appState", "updatedAt", "title", "isPinned"]
    },
    "Admin": {
      "title": "Admin",
      "description": "Admin user allowed to invite and view dashboard",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "The admin's email address"
        },
        "addedBy": {
          "type": "string",
          "description": "The email of the admin who invited this admin"
        },
        "createdAt": {
          "type": "number",
          "description": "Timestamp of creation"
        }
      },
      "required": ["email", "addedBy", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}/sessions/{sessionId}": {
      "schema": {
        "$ref": "#/entities/Session"
      },
      "description": "Stores user chat sessions and states"
    },
    "/admins/{adminEmail}": {
      "schema": {
        "$ref": "#/entities/Admin"
      },
      "description": "Stores admin users by email"
    }
  }
}

