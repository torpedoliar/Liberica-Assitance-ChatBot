{
  "entities": {
    "Session": {
      "title": "Session",
      "description": "User session containing chat history and app state",
      "type": "object",
      "properties": {
        "currentMode": {
          "type": "string",
          "description": "The current mode of the app"
        },
        "messages": {
          "type": "string",
          "description": "JSON stringified messages"
        },
        "appState": {
          "type": "string",
          "description": "JSON stringified app state"
        },
        "updatedAt": {
          "type": "number",
          "description": "Timestamp of last update"
        },
        "title": {
          "type": "string",
          "description": "The title of the session"
        },
        "isPinned": {
          "type": "boolean",
          "description": "Whether the session is pinned"
        }
      },
      "required": ["currentMode", "messages", "appState", "updatedAt", "title", "isPinned"]
    }
  },
  "firestore": {
    "/users/{userId}/sessions/{sessionId}": {
      "schema": {
        "$ref": "#/entities/Session"
      },
      "description": "Stores user chat sessions and states"
    }
  }
}
